# =====================================================================
#  설정 파일 사용법
#  이 파일을 복사해서 이름을 ".env" 로 바꾸고 아래 값을 채워주세요.
#  (setup.bat을 실행하면 자동으로 만들어줍니다)
# =====================================================================


# ─────────────────────────────────────────────
#  트위터 토큰 (필수)
#  어디서 구하나요?
#    1. 크롬/엣지에서 x.com (트위터) 로그인
#    2. F12 키 누르기 → 상단 탭에서 "Application" 클릭
#    3. 왼쪽 메뉴 "Cookies" → "https://x.com" 클릭
#    4. 목록에서 "ct0" 찾아서 Value 열 값 복사 → CT0에 붙여넣기
#    5. 목록에서 "auth_token" 찾아서 Value 열 값 복사 → AUTH_TOKEN에 붙여넣기
#  주의: 토큰은 로그아웃하거나 비밀번호 변경 시 만료됩니다.
# ─────────────────────────────────────────────
TWITTER_CT0=여기에_ct0_값_붙여넣기
TWITTER_AUTH_TOKEN=여기에_auth_token_값_붙여넣기


# ─────────────────────────────────────────────
#  Notion 토큰 (필수)
#  어디서 구하나요?
#    1. https://www.notion.so/my-integrations 접속
#    2. "+ 새 API 통합 만들기" 클릭
#    3. 이름 아무거나 입력 (예: 트위터북마크) → 제출
#    4. "내부 통합 시크릿" 옆 "표시" 클릭 → 복사 → 아래에 붙여넣기
#    5. 북마크를 저장할 Notion 페이지 열기
#    6. 오른쪽 상단 "..." → "연결" → 방금 만든 통합 이름 클릭해서 연결
# ─────────────────────────────────────────────
NOTION_TOKEN=여기에_Notion_시크릿_붙여넣기


# ─────────────────────────────────────────────
#  Notion 부모 페이지 ID (필수)
#  어디서 구하나요?
#    북마크 DB를 만들 Notion 페이지 URL에서 복사합니다.
#    예시 URL: https://www.notion.so/내이름/페이지이름-abc123def456...
#    URL 맨 끝 32자리 영문+숫자가 페이지 ID입니다.
#    예: abc123def456abc123def456abc123de
# ─────────────────────────────────────────────
NOTION_PARENT_PAGE_ID=여기에_페이지ID_붙여넣기


# ─────────────────────────────────────────────
#  Gemini API 키 (선택 — 없어도 기본 기능은 모두 동작합니다)
#  "기타"로 분류된 트윗을 AI가 재분류할 때만 필요합니다.
#  어디서 구하나요?
#    1. https://aistudio.google.com/app/apikey 접속 (구글 계정 로그인)
#    2. "+ API 키 만들기" 클릭 → 복사 → 아래에 붙여넣기
#  무료 플랜으로 충분합니다 (분당 15회 제한).
# ─────────────────────────────────────────────
GEMINI_API_KEY=여기에_Gemini_키_붙여넣기
